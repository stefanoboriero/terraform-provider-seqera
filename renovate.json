{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "prHourlyLimit": 0,
  "enabledManagers": ["custom.regex"],
  "customDatasources": {
    "seqera-platform-api": {
      "defaultRegistryUrlTemplate": "https://cloud.dev-seqera.io/openapi/seqera-api-latest.yml",
      "format": "yaml",
      "transformTemplates": [
        "{ \"releases\": [ { \"version\": info.version, \"isStable\": true } ] }"
      ]
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track the Seqera Platform API version embedded in the Speakeasy gen.lock",
      "fileMatch": ["^\\.speakeasy/gen\\.lock$"],
      "matchStrings": [
        "docVersion: (?<currentValue>[\\d\\.]+)"
      ],
      "depNameTemplate": "seqera-platform-api",
      "datasourceTemplate": "custom.seqera-platform-api",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "description": "Track the Seqera Platform API version in the buildJavaClient Gradle task",
      "fileMatch": ["^build\\.gradle$"],
      "matchStrings": [
        "tasks\\.register\\('buildJavaClient'[\\s\\S]*?artifactVersion:\\s*\"(?<currentValue>[\\d\\.]+)\""
      ],
      "depNameTemplate": "seqera-platform-api",
      "datasourceTemplate": "custom.seqera-platform-api",
      "versioningTemplate": "semver-coerced"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["custom.seqera-platform-api"],
      "automerge": false,
      "recreateClosed": true,
      "labels": ["api-update"],
      "commitMessageTopic": "Seqera Platform API",
      "branchName": "renovate/seqera-api-{{{newVersion}}}"
    }
  ],
  "postUpgradeTasks": {
    "commands": [
      "curl -fsSL 'https://cloud.dev-seqera.io/openapi/seqera-api-latest.yml' -o specs/seqera-api-cloud.yaml"
    ],
    "fileFilters": [
      "specs/seqera-api-cloud.yaml",
      "internal/**",
      ".speakeasy/out.openapi.yaml",
      ".speakeasy/workflow.lock",
      ".speakeasy/gen.lock",
      "docs/**",
      "go.sum"
    ],
    "executionMode": "branch"
  }
}
